{
  "name": "mirofish-b-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node dev-server.mjs",
    "build:pages": "node scripts/build-pages.mjs",
    "deploy:pages": "npm run build:pages && npx wrangler pages deploy dist-pages --project-name my-mirofish-b --branch main --commit-dirty=true",
    "deploy:worker": "npx wrangler deploy -c wrangler.worker.toml",
    "deploy": "npm run deploy:pages && npm run deploy:worker",
    "prod:inspect": "node scripts/inspect-production-analytics.mjs --d1 --skip-health",
    "prod:inspect:remote": "node scripts/inspect-production-analytics.mjs"
  },
  "dependencies": {
    "pg": "^8.20.0",
    "ssh2": "^1.17.0"
  }
}
